PORT=5000
CLIENT_ORIGIN=http://localhost:5173

GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_FALLBACK_MODELS=gemini-2.5-flash-image

TRIPO_API_KEY=your-tripo-api-key
TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi
TRIPO_MODEL_VERSION=v3.1-20260211

TRIPO_TEXTURE=true
TRIPO_PBR=true
TRIPO_RIG_FORMAT=glb
TRIPO_RIG_TYPE=biped
TRIPO_TEXTURE_QUALITY=standard
TRIPO_TEXTURE_ALIGNMENT=original_image

TRIPO_ORIENTATION=default
TRIPO_IDLE_ANIMATION_TASK_TYPE=animate_retarget
TRIPO_IDLE_ANIMATION_NAME=preset:walk
TRIPO_IDLE_ANIMATION_IN_PLACE=true
TRIPO_RIG_SPEC=tripo
TRIPO_RIG_MODEL_VERSION=v1.0-20240301

PIXELLAB_API_KEY=your-pixellab-api-key
PIXELLAB_BASE_URL=https://api.pixellab.ai/v1
